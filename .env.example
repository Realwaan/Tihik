# Database (PostgreSQL connection string for Prisma)
DATABASE_URL="postgresql://username:password@localhost:5432/trackit_db?schema=public"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-strong-random-secret"

# OAuth Providers (Optional for V1, but good to scaffold)
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# Optional providers
GITHUB_CLIENT_ID="your_github_client_id"
GITHUB_CLIENT_SECRET="your_github_client_secret"
DISCORD_CLIENT_ID="your_discord_client_id"
DISCORD_CLIENT_SECRET="your_discord_client_secret"
FACEBOOK_CLIENT_ID="your_facebook_client_id"
FACEBOOK_CLIENT_SECRET="your_facebook_client_secret"

# AI providers
GEMINI_API_KEY="your_gemini_api_key"
OPENAI_API_KEY="your_openai_api_key"
NVIDIA_API_KEY="your_nvidia_api_key"
NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"
NVIDIA_MODEL="nvidia/nemotron-3-super-120b-a12b"
# Optional NVIDIA tuning
# NVIDIA_TEMPERATURE="1"
# NVIDIA_TOP_P="0.95"
# NVIDIA_MAX_TOKENS="16384"
# NVIDIA_REASONING_BUDGET="16384"

# Email verification (SMTP)
SMTP_HOST="smtp.your-provider.com"
SMTP_PORT="587"
SMTP_USER="your_smtp_username"
SMTP_PASS="your_smtp_password"
SMTP_FROM="TrackIt <no-reply@your-domain.com>"

# Read-only bank API integration
BANK_TOKEN_ENCRYPTION_KEY="set-a-long-random-secret-at-least-32-characters"
BANK_API_BASE_URL="https://api.your-bank-provider.com"
BANK_API_TRANSACTIONS_PATH="/transactions"

# Optional local bank mock/testing
BANK_MOCK_PORT="4010"
BANK_SAMPLE_ACCESS_TOKEN="sample-read-token"
